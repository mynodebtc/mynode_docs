// VuePress default theme Stylus variables
// These are injected BEFORE the theme compiles — so the theme builds
// with these values rather than needing to be overridden afterward.

$accentColor    = #F08E20
$textColor      = rgba(255,255,255,0.55)
$borderColor    = rgba(255,255,255,0.08)
$codeBgColor    = rgba(255,255,255,0.04)
$arrowBgColor   = rgba(255,255,255,0.30)

$navbarHeight   = 68px
$sidebarWidth   = 20rem
$contentWidth   = 800px
$homePageWidth  = 960px
